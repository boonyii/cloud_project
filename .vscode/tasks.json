{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Task Service",
            "type": "shell",
            "command": "py -m uvicorn services.task_service:task_app --port 8001 --reload",
            "presentation": { "panel": "dedicated", "group": "services" },
            "isBackground": true
        },
        {
            "label": "Scheduler Service",
            "type": "shell",
            "command": "py -m uvicorn services.scheduler_service:schedule_app --port 8002 --reload",
            "presentation": { "panel": "dedicated", "group": "services" },
            "isBackground": true
        },
        {
            "label": "Trend Service",
            "type": "shell",
            "command": "py -m uvicorn services.trend_service:trend_app --port 8003 --reload",
            "presentation": { "panel": "dedicated", "group": "services" },
            "isBackground": true
        },
        {
            "label": "GitHub Service",
            "type": "shell",
            "command": "py -m uvicorn services.github_service:github_app --port 8004 --reload",
            "presentation": { "panel": "dedicated", "group": "services" },
            "isBackground": true
        },
        {
            "label": "API Gateway",
            "type": "shell",
            "command": "py -m uvicorn api_gateway.main:app --port 8000 --reload",
            "presentation": { "panel": "dedicated", "group": "services" },
            "isBackground": true
        },
        {
            "label": "Start All Services",
            "dependsOrder": "parallel",
            "dependsOn": [
                "Task Service",
                "Scheduler Service",
                "Trend Service",
                "GitHub Service",
                "API Gateway"
            ],
            "group": { "kind": "build", "isDefault": true },
            "presentation": { "reveal": "always" }
        }
    ]
}
